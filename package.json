{
  "name": "fund-manager",
  "version": "1.0.0",
  "description": "Collective Fund Management System",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "NODE_ENV=production node server/index.js",
    "install:all": "npm install && npm install --prefix client",
    "render-build": "npm run install:all && npm run build --prefix client"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "nepali-date-library": "^1.1.11",
    "nodemailer": "^8.0.3",
    "xlsx": "^0.18.5"
  }
}
